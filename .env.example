# ZK Circuit Configuration
# Copy this file to .env and modify values as needed.
# Priority: environment variable > .env file > profile defaults

# Profile Selection
# "dev"  — small parameters for fast builds and local testing (default)
# "prod" — production parameters for deployment
ZK_PROFILE=dev

# ┌─────────────────────────┬──────┬──────┐
# │ Parameter               │ dev  │ prod │
# ├─────────────────────────┼──────┼──────┤
# │ ZK_MAX_JWT_B64_LEN      │ 1024 │ 1024 │
# │ ZK_MAX_PAYLOAD_B64_LEN  │  640 │  896 │
# │ ZK_MAX_AUD_LEN          │  155 │  155 │
# │ ZK_MAX_EXP_LEN          │   20 │   20 │
# │ ZK_MAX_ISS_LEN          │   93 │   93 │
# │ ZK_MAX_NONCE_LEN        │   93 │   93 │
# │ ZK_MAX_SUB_LEN          │   93 │   93 │
# │ ZK_N                    │    6 │    6 │
# │ ZK_K                    │    3 │    3 │
# │ ZK_TREE_HEIGHT          │    4 │   16 │
# │ ZK_NUM_AUDIENCE_LIMIT   │    5 │    5 │
# └─────────────────────────┴──────┴──────┘

# Individual overrides (uncomment to override profile defaults):
# ZK_MAX_JWT_B64_LEN=1024
# ZK_MAX_PAYLOAD_B64_LEN=640
# ZK_MAX_AUD_LEN=155
# ZK_MAX_EXP_LEN=20
# ZK_MAX_ISS_LEN=93
# ZK_MAX_NONCE_LEN=93
# ZK_MAX_SUB_LEN=93
# ZK_N=6
# ZK_K=3
# ZK_TREE_HEIGHT=4
# ZK_NUM_AUDIENCE_LIMIT=5
