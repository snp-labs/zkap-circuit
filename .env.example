# ZK Circuit Parameters
# Copy this file to .env and modify values for experimentation.
# Priority: environment variable > .env file > hardcoded defaults below.

# JWT Constraints
ZK_MAX_JWT_B64_LEN=1024
ZK_MAX_PAYLOAD_B64_LEN=640
ZK_MAX_AUD_LEN=155
ZK_MAX_EXP_LEN=20
ZK_MAX_ISS_LEN=93
ZK_MAX_NONCE_LEN=93
ZK_MAX_SUB_LEN=93

# Anchor Parameters
ZK_N=6
ZK_K=3

# Merkle Tree
ZK_TREE_HEIGHT=4

# Audience
ZK_NUM_AUDIENCE_LIMIT=5
